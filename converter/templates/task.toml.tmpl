schema_version = "1.2"

[task]
name = "repo2run/__SLUG__"
description = "Configure __OWNER__/__REPO__@__SHORT_SHA__ so pytest --collect-only succeeds."
keywords = ["repo2run", "python", "build-configuration", "environment-setup"]

[metadata]
source = "repo2run"
upstream_repo = "__OWNER__/__REPO__"
base_commit = "__SHA__"
paper = "arXiv:2502.13681"
criterion = "__CRITERION_NAME__"

[environment]
build_timeout_sec = 900.0
cpus = 2
memory_mb = 4096
storage_mb = 10240
allow_internet = true

[verifier]
timeout_sec = 300.0

[agent]
timeout_sec = 1800.0
